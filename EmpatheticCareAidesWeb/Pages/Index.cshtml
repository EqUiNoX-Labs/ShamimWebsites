@page
@model IndexModel

<section class="hero" id="S1">
    <div class="hero-bg" aria-hidden="true">
        <div class="hero-bg-slides" data-hero-slides>
            <div class="hero-bg-slide is-active">
                <img src="~/images/banner.jpg" asp-append-version="true" alt="" width="1920" height="1080" decoding="async" fetchpriority="high" />
            </div>
            <div class="hero-bg-slide">
                <img src="~/images/hero-wheelchair-care.jpg" asp-append-version="true" alt="" width="1600" height="1067" loading="lazy" decoding="async" />
            </div>
            <div class="hero-bg-slide">
                <img src="~/images/hero-mealtime-care.jpg" asp-append-version="true" alt="" width="1200" height="800" loading="lazy" decoding="async" />
            </div>
            <div class="hero-bg-slide">
                <img src="~/images/hero-companionship.jpg" asp-append-version="true" alt="" width="1200" height="800" loading="lazy" decoding="async" />
            </div>
        </div>
        <div class="hero-bg-tint"></div>
        <div class="hero-bg-glow"></div>
    </div>
    <div class="container py-4">
        <div class="row align-items-center">
            <div class="col-lg-8 reveal">
                <p class="text-uppercase small text-white-50 mb-2 letter-spacing-1">Leduc &amp; Edmonton region</p>
                <h1 class="hero-tagline mb-3">Home care rooted in empathy</h1>
                <p class="hero-lead mb-4">
                    Empathetic Care Aides pairs skilled Registered Care Aides with respectful, person-centred support—so clients feel heard at home, in facility settings, or wherever they need an extra hand.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a class="btn btn-eca btn-lg" href="mailto:info@empatheticcareaides.com?subject=Free%20consultation">Request a free consultation</a>
                    <a class="btn btn-outline-light btn-lg rounded-pill" href="tel:+16044402458">Call 604 440 2458</a>
                </div>
            </div>
        </div>
    </div>
    <div class="hero-wave" aria-hidden="true"></div>
</section>

<section class="eca-trust-strip" aria-label="Why reach out">
    <div class="container py-4">
        <div class="row g-3 g-md-4 justify-content-center">
            <div class="col-6 col-lg-4">
                <div class="eca-trust-card reveal stagger-1">
                    <span class="eca-trust-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" stroke-linecap="round" /></svg>
                    </span>
                    <strong class="eca-trust-title">24/7 response</strong>
                    <span class="eca-trust-desc">Questions answered any time, any day</span>
                </div>
            </div>
            <div class="col-6 col-lg-4">
                <div class="eca-trust-card reveal stagger-2">
                    <span class="eca-trust-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l8 4v5c0 5-3.5 9.5-8 10.5-4.5-1-8-5.5-8-10.5V7l8-4z" /><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    </span>
                    <strong class="eca-trust-title">Registered Care Aides</strong>
                    <span class="eca-trust-desc">Trained, respectful, person-centred care</span>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="eca-trust-card reveal stagger-3">
                    <span class="eca-trust-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-8-4.5-8-11a8 8 0 0 1 16 0c0 6.5-8 11-8 11z" /><circle cx="12" cy="11" r="3" /></svg>
                    </span>
                    <strong class="eca-trust-title">Leduc &amp; region</strong>
                    <span class="eca-trust-desc">Local team, flexible scheduling</span>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container pb-5">
    <div class="row mb-5">
        <div class="col-lg-10 mx-auto text-center reveal">
            <p class="lead text-secondary mb-0">
                Clinical skill matters—but empathy is what turns good care into trusted care. We combine both, with flexible scheduling and plans designed to stay affordable.
            </p>
        </div>
    </div>

    <section class="mb-5 pb-4" id="S2">
        <h2 class="section-title anchor">Why families choose us</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card reveal stagger-1">
                    <div class="feature-icon" aria-hidden="true">
                        <svg class="feature-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-8-4.5-8-11a8 8 0 0 1 16 0c0 6.5-8 11-8 11z" /><circle cx="12" cy="11" r="3" /></svg>
                    </div>
                    <h3 class="h5">Empathy first</h3>
                    <p class="text-secondary mb-0">We listen, validate concerns, and build rapport—supporting emotional well-being alongside physical needs.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card reveal stagger-2">
                    <div class="feature-icon" aria-hidden="true">
                        <svg class="feature-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l8 4v5c0 5-3.5 9.5-8 10.5-4.5-1-8-5.5-8-10.5V7l8-4z" /><path d="M9 12l2 2 4-4" /></svg>
                    </div>
                    <h3 class="h5">Skilled care</h3>
                    <p class="text-secondary mb-0">Registered Care Aides bring training, judgment, and gentle technique to personal care, safety, and daily living.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card reveal stagger-3">
                    <div class="feature-icon" aria-hidden="true">
                        <svg class="feature-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
                    </div>
                    <h3 class="h5">Flexible &amp; affordable</h3>
                    <p class="text-secondary mb-0">Hourly, daily, or overnight options—clear communication and plans shaped around your budget and routine.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5 pb-4" id="S3">
        <h2 class="section-title anchor">Service area</h2>
        <p class="text-secondary col-lg-9 reveal">
            Based in <strong>Leduc, Alberta</strong>, we support clients and families in Leduc and nearby communities, including south Edmonton and Leduc County. Not sure if you are in range?
            <a href="mailto:info@empatheticcareaides.com">Send us a note</a>—we are happy to help.
        </p>
        <div class="row g-3 reveal">
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Leduc</strong></div></div>
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Edmonton</strong></div></div>
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Beaumont</strong></div></div>
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Nisku</strong></div></div>
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Calmar</strong></div></div>
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Devon</strong></div></div>
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Wetaskiwin</strong></div></div>
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Millet</strong></div></div>
            <div class="col-sm-6 col-md-4"><div class="feature-card py-3 text-center mb-0"><strong>Leduc County</strong></div></div>
        </div>
        <p class="small text-muted mt-3 mb-0 reveal">Additional areas may be available—ask when you arrange a consultation.</p>
    </section>

    <section class="mb-5 pb-4" id="S4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6 order-lg-2 reveal">
                <h2 class="section-title anchor">What is empathy in health care?</h2>
                <p class="text-secondary">
                    Empathy means understanding and sharing how clients feel—not only treating symptoms, but acknowledging fear, fatigue, and dignity. It improves trust, adherence to care plans, and day-to-day quality of life.
                </p>
                <p class="text-secondary mb-0">
                    Our team practises empathy with clients <em>and</em> with families, so communication stays clear and everyone feels supported.
                </p>
            </div>
            <div class="col-lg-6 order-lg-1 reveal stagger-2">
                <div class="rounded-4 overflow-hidden shadow" style="aspect-ratio: 4/3;">
                    <img class="w-100 h-100 eca-img-cover"
                         src="~/images/empathy.jpg"
                         asp-append-version="true"
                         alt="Empathy in health care — supportive connection with clients"
                         width="1200"
                         height="800"
                         loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5 pb-4" id="S5">
        <h2 class="section-title anchor">Our pledge &amp; mission</h2>
        <div class="row g-4">
            <div class="col-lg-6 reveal">
                <h3 class="h5">Our pledge to you</h3>
                <p class="text-secondary">We aim to provide high-quality care and respect for privacy so needs are met while clients live as fully and comfortably as possible.</p>
                <p class="text-secondary mb-0">Whenever we can, we match carers to client preferences—for example, aligning male clients with male carers and female clients with female carers when requested.</p>
            </div>
            <div class="col-lg-6 reveal stagger-2">
                <h3 class="h5">Our mission</h3>
                <p class="text-secondary mb-0">We strive to create a caring environment and be recognized as a trusted home care provider across the Leduc and Edmonton region—building excellent relationships with families and delivering the quality of care every client deserves, at a cost-effective value.</p>
            </div>
        </div>
    </section>

    <section class="mb-5 pb-4" id="S6">
        <h2 class="section-title anchor">Our services</h2>
        <p class="text-secondary col-lg-10 mb-4 reveal">
            We place skilled Registered Care Aides in homes and care facilities—supporting independence with patience and respect. Explore categories below; we will tailor an affordable plan to your situation.
        </p>
        <div class="accordion eca-accordion reveal" id="servicesAccordion">
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#svc1">Personal care &amp; hygiene</button>
                </h3>
                <div id="svc1" class="accordion-collapse collapse show" data-bs-parent="#servicesAccordion">
                    <div class="accordion-body">
                        <ul class="mb-0">
                            <li>Bathing and showering assistance</li>
                            <li>Dressing and grooming assistance</li>
                            <li>Toileting and incontinence care</li>
                            <li>Mobility assistance within the home</li>
                            <li>Oral care, nail care, hair care and shaving</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#svc2">Meals &amp; medication support</button>
                </h3>
                <div id="svc2" class="accordion-collapse collapse" data-bs-parent="#servicesAccordion">
                    <div class="accordion-body">
                        <p class="fw-semibold mb-1">Meal preparation</p>
                        <ul>
                            <li>Planning and preparing nutritious meals</li>
                            <li>Assisting with feeding when needed</li>
                            <li>Special diets and dietary restrictions</li>
                        </ul>
                        <p class="fw-semibold mb-1">Medication management</p>
                        <ul class="mb-0">
                            <li>Medication reminders</li>
                            <li>Assistance with medication administration</li>
                            <li>Medication organization</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#svc3">Companionship, emotional support &amp; respite</button>
                </h3>
                <div id="svc3" class="accordion-collapse collapse" data-bs-parent="#servicesAccordion">
                    <div class="accordion-body">
                        <ul>
                            <li>Conversation, social interaction, outings</li>
                            <li>Recreational activities</li>
                            <li>Emotional and psychological support; monitoring well-being</li>
                            <li>Addressing loneliness and anxiety</li>
                            <li>Respite for family caregivers with continuous client care</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#svc4">Home, errands &amp; transportation</button>
                </h3>
                <div id="svc4" class="accordion-collapse collapse" data-bs-parent="#servicesAccordion">
                    <div class="accordion-body">
                        <ul>
                            <li>Light housekeeping, laundry, linens, organizing</li>
                            <li>Grocery and household shopping; pharmacy pickups</li>
                            <li>Medical appointments and social outings</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#svc5">Mobility &amp; transfers</button>
                </h3>
                <div id="svc5" class="accordion-collapse collapse" data-bs-parent="#servicesAccordion">
                    <div class="accordion-body">
                        <ul class="mb-0">
                            <li>Transfers in and out of bed or chair</li>
                            <li>Ambulation and walking support</li>
                            <li>Use of wheelchairs, walkers, and other aids</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#svc6">Dementia, clinical &amp; safety</button>
                </h3>
                <div id="svc6" class="accordion-collapse collapse" data-bs-parent="#servicesAccordion">
                    <div class="accordion-body">
                        <p class="fw-semibold mb-1">Alzheimer&apos;s &amp; dementia care</p>
                        <ul>
                            <li>Specialized memory support, engagement, behaviour strategies</li>
                        </ul>
                        <p class="fw-semibold mb-1">End-of-life care</p>
                        <ul>
                            <li>Comfort care, pain management, family support, preparations</li>
                        </ul>
                        <p class="fw-semibold mb-1">Home safety &amp; clinical supports</p>
                        <ul>
                            <li>Home safety assessment, fall prevention, hazard review</li>
                            <li>Wound care: dressing changes, monitoring, infection prevention</li>
                            <li>Chronic condition support (e.g. diabetes), vitals, lifestyle coaching</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#svc7">Scheduling options</button>
                </h3>
                <div id="svc7" class="accordion-collapse collapse" data-bs-parent="#servicesAccordion">
                    <div class="accordion-body">
                        <p class="text-secondary mb-2">Whatever your needs, we can design an affordable plan:</p>
                        <ul class="mb-0">
                            <li>Hourly</li>
                            <li>Daily</li>
                            <li>Overnight</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5 pb-4" id="S7">
        <h2 class="section-title anchor">About us</h2>
        <div class="row g-4 align-items-center">
            <div class="col-lg-7 reveal">
                <blockquote class="quote-block mb-4">
                    &ldquo;Empathy is simply listening, holding space, withholding judgment, emotionally connecting, and communicating that incredibly healing message of &lsquo;You&rsquo;re not alone.&rsquo;&rdquo; <span class="text-secondary fs-6 fst-normal">— Brené Brown</span>
                </blockquote>
                <p class="text-secondary">
                    Empathetic Care Aides is locally owned and operated in <strong>Leduc, Alberta</strong> by health care professionals dedicated to helping people live safely and comfortably at home. Staff are reliable, dependable, flexible, compassionate, and sensitive to each client&apos;s needs.
                </p>
            </div>
            <div class="col-lg-5 reveal stagger-2">
                <div class="rounded-4 overflow-hidden shadow" style="aspect-ratio: 4/3;">
                    <img class="w-100 h-100 eca-img-cover"
                         src="~/images/banner.jpg"
                         asp-append-version="true"
                         alt="Empathetic Care Aides — compassionate home care"
                         width="1600"
                         height="900"
                         loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <section class="py-5 my-4 rounded-4 text-white text-center eca-contact-band" id="S8">
        <div class="container anchor py-2">
            <h2 class="text-white mb-3">Contact us</h2>
            <p class="text-white-50 col-lg-8 mx-auto mb-4">
                Free consultation. We answer questions about services, coverage in your community, and how to get started—24 hours a day, 7 days a week.
            </p>
            <div class="d-flex flex-column flex-md-row justify-content-center align-items-center gap-3 gap-md-4">
                <a class="btn btn-eca btn-lg d-inline-flex align-items-center justify-content-center gap-2" href="tel:+16044402458">
                    <svg class="btn-cta-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    <span>604 440 2458</span>
                </a>
                <a class="btn btn-outline-light btn-lg rounded-pill d-inline-flex align-items-center justify-content-center gap-2" href="mailto:info@empatheticcareaides.com">
                    <svg class="btn-cta-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke-linecap="round" stroke-linejoin="round" /><path d="m22 6-10 7L2 6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    <span>info@empatheticcareaides.com</span>
                </a>
            </div>
        </div>
    </section>
</div>
